{
  "expo": {
    "name": "eBike",
    "slug": "ebike",
    "scheme": "ebike",
    "version": "1.6.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ebikeland.app",
      "buildNumber": "18",
      "infoPlist": {
        "NSCameraUsageDescription": "eBike uses the camera to capture photos inside the app before you publish them.",
        "NSPhotoLibraryUsageDescription": "eBike accesses your photo library to let you choose media that appears in the app.",
        "NSLocationWhenInUseUsageDescription": "eBike uses your location to display your position on in-app maps and surface nearby points of interest.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.ebike.app",
      "versionCode": 18,
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#052e16"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8db8d6d-30a7-4c1d-bcdb-6fa7f5b601e3"
      }
    },
    "owner": "elvisebike"
  }
}
